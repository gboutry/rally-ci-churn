{% set title = title or "Ring east-west network benchmark" %}
{% set description = description or "One controller plus many participants communicating in a bounded ring topology" %}
{% set cloud_cfg = cloud or {} %}
{% set network_cfg = network or {} %}
{% set user_cfg = users or {} %}
{% set quota_cfg = quotas or {} %}
{% set nova_quota_cfg = quota_cfg.nova if quota_cfg.nova is defined else {} %}
{% set cinder_quota_cfg = quota_cfg.cinder if quota_cfg.cinder is defined else {} %}
{% set neutron_quota_cfg = quota_cfg.neutron if quota_cfg.neutron is defined else {} %}
{% set controller_cfg = controller or {} %}
{% set traffic_cfg = traffic or {} %}
{% set ring_cfg = ring or {} %}
{% set artifacts_cfg = artifacts or {} %}
{% set boot_volume_cfg = boot_volume or {} %}
---
version: 2
title: "{{ title }}"
description: "{{ description }}"
tags:
  - rally
  - openstack
  - network
  - iperf3
  - ring
  - east-west
subtasks:
  - title: "Ring east-west network run"
    description: "Boot one controller and many benchmark participants"
    contexts:
      users@openstack:
        tenants: {{ user_cfg.tenants or 1 }}
        users_per_tenant: {{ user_cfg.users_per_tenant or 1 }}
      quotas@openstack:
        nova:
          instances: {{ nova_quota_cfg.instances if nova_quota_cfg.instances is defined else -1 }}
          cores: {{ nova_quota_cfg.cores if nova_quota_cfg.cores is defined else -1 }}
          ram: {{ nova_quota_cfg.ram if nova_quota_cfg.ram is defined else -1 }}
          floating_ips: {{ nova_quota_cfg.floating_ips if nova_quota_cfg.floating_ips is defined else -1 }}
          fixed_ips: {{ nova_quota_cfg.fixed_ips if nova_quota_cfg.fixed_ips is defined else -1 }}
          key_pairs: {{ nova_quota_cfg.key_pairs if nova_quota_cfg.key_pairs is defined else -1 }}
          security_groups: {{ nova_quota_cfg.security_groups if nova_quota_cfg.security_groups is defined else -1 }}
          security_group_rules: {{ nova_quota_cfg.security_group_rules if nova_quota_cfg.security_group_rules is defined else -1 }}
        cinder:
          gigabytes: {{ cinder_quota_cfg.gigabytes if cinder_quota_cfg.gigabytes is defined else -1 }}
          snapshots: {{ cinder_quota_cfg.snapshots if cinder_quota_cfg.snapshots is defined else -1 }}
          volumes: {{ cinder_quota_cfg.volumes if cinder_quota_cfg.volumes is defined else -1 }}
        neutron:
          network: {{ neutron_quota_cfg.network if neutron_quota_cfg.network is defined else -1 }}
          subnet: {{ neutron_quota_cfg.subnet if neutron_quota_cfg.subnet is defined else -1 }}
          port: {{ neutron_quota_cfg.port if neutron_quota_cfg.port is defined else -1 }}
          router: {{ neutron_quota_cfg.router if neutron_quota_cfg.router is defined else -1 }}
          floatingip: {{ neutron_quota_cfg.floatingip if neutron_quota_cfg.floatingip is defined else -1 }}
          security_group: {{ neutron_quota_cfg.security_group if neutron_quota_cfg.security_group is defined else -1 }}
          security_group_rule: {{ neutron_quota_cfg.security_group_rule if neutron_quota_cfg.security_group_rule is defined else -1 }}
      network@openstack:
        start_cidr: "{{ network_cfg.start_cidr or '10.79.0.0/22' }}"
        networks_per_tenant: 1
        subnets_per_network: 1
{% if network_cfg.dns_nameservers %}
        dns_nameservers:
{% for dns_nameserver in network_cfg.dns_nameservers %}
          - "{{ dns_nameserver }}"
{% endfor %}
{% endif %}
        router:
          external_gateway_info:
            network_id: "{{ cloud_cfg.external_network_id }}"
    scenario:
      CIChurn.net_ring:
        controller_image:
          name: "{{ cloud_cfg.controller_image_name }}"
        controller_flavor:
          name: "{{ cloud_cfg.controller_flavor_name }}"
        participant_image:
          name: "{{ cloud_cfg.participant_image_name or cloud_cfg.controller_image_name }}"
        participant_flavor:
          name: "{{ cloud_cfg.participant_flavor_name or cloud_cfg.controller_flavor_name }}"
        external_network_name: "{{ cloud_cfg.external_network_name }}"
        ssh_user: "{{ controller_cfg.ssh_user or 'ubuntu' }}"
        ssh_connect_timeout_seconds: {{ controller_cfg.ssh_connect_timeout_seconds or 300 }}
        command_timeout_seconds: {{ controller_cfg.command_timeout_seconds or 0 }}
        boot_concurrency: {{ controller_cfg.boot_concurrency or 1 }}
        boot_from_volume: {{ boot_volume_cfg.enabled or false }}
        root_volume_size_gib: {{ boot_volume_cfg.size_gib or 20 }}
{% if boot_volume_cfg.volume_type is defined and boot_volume_cfg.volume_type is not none %}
        root_volume_type: "{{ boot_volume_cfg.volume_type }}"
{% else %}
        root_volume_type: null
{% endif %}
        participant_count: {{ ring_cfg.participant_count or 8 }}
        protocols: {{ traffic_cfg.protocols or ['tcp', 'udp'] }}
        duration_seconds: {{ traffic_cfg.duration_seconds or 20 }}
        ramp_time_seconds: {{ traffic_cfg.ramp_time_seconds or 5 }}
        base_port: {{ traffic_cfg.base_port or 5201 }}
        neighbors_per_vm: {{ ring_cfg.neighbors_per_vm or 1 }}
        bidirectional: {{ ring_cfg.bidirectional if ring_cfg.bidirectional is defined else true }}
        parallel_streams: {{ traffic_cfg.parallel_streams or [4] }}
        udp_target_mbps: {{ traffic_cfg.udp_target_mbps or [300] }}
        artifacts_root_dir: "{{ artifacts_cfg.root_dir or 'artifacts' }}"
    runner:
      constant:
        times: 1
        concurrency: 1
        timeout: {{ controller_cfg.command_timeout_seconds or 0 if (controller_cfg.command_timeout_seconds or 0) > 0 else 86400 }}
    sla:
      failure_rate:
        max: 0
