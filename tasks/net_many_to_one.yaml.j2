{% set title = title or "Many-to-one network benchmark" %}
{% set description = description or "One server, many clients, and one controller over a tenant overlay network" %}
{% set cloud_cfg = cloud or {} %}
{% set network_cfg = network or {} %}
{% set controller_cfg = controller or {} %}
{% set traffic_cfg = traffic or {} %}
{% set many_cfg = many_to_one or {} %}
{% set volume_cfg = server_volume or {} %}
{% set artifacts_cfg = artifacts or {} %}
---
version: 2
title: "{{ title }}"
description: "{{ description }}"
tags:
  - rally
  - openstack
  - network
  - iperf3
  - east-west
subtasks:
  - title: "Many-to-one network run"
    description: "Boot one controller, one benchmark server, and many clients"
    contexts:
      network@openstack:
        start_cidr: "{{ network_cfg.start_cidr or '10.78.0.0/22' }}"
        networks_per_tenant: 1
        subnets_per_network: 1
{% if network_cfg.dns_nameservers %}
        dns_nameservers:
{% for dns_nameserver in network_cfg.dns_nameservers %}
          - "{{ dns_nameserver }}"
{% endfor %}
{% endif %}
        router:
          external_gateway_info:
            network_id: "{{ cloud_cfg.external_network_id }}"
    scenario:
      CIChurn.net_many_to_one:
        controller_image:
          name: "{{ cloud_cfg.controller_image_name }}"
        controller_flavor:
          name: "{{ cloud_cfg.controller_flavor_name }}"
        server_image:
          name: "{{ cloud_cfg.server_image_name or cloud_cfg.controller_image_name }}"
        server_flavor:
          name: "{{ cloud_cfg.server_flavor_name or cloud_cfg.controller_flavor_name }}"
        client_image:
          name: "{{ cloud_cfg.client_image_name or cloud_cfg.server_image_name or cloud_cfg.controller_image_name }}"
        client_flavor:
          name: "{{ cloud_cfg.client_flavor_name or cloud_cfg.server_flavor_name or cloud_cfg.controller_flavor_name }}"
        external_network_name: "{{ cloud_cfg.external_network_name }}"
        ssh_user: "{{ controller_cfg.ssh_user or 'ubuntu' }}"
        ssh_connect_timeout_seconds: {{ controller_cfg.ssh_connect_timeout_seconds or 300 }}
        command_timeout_seconds: {{ controller_cfg.command_timeout_seconds or 0 }}
        client_count: {{ many_cfg.client_count or 8 }}
        mode: "{{ traffic_cfg.mode or 'iperf3' }}"
        protocols: {{ traffic_cfg.protocols or ['tcp', 'udp'] }}
        duration_seconds: {{ traffic_cfg.duration_seconds or 20 }}
        ramp_time_seconds: {{ traffic_cfg.ramp_time_seconds or 5 }}
        base_port: {{ traffic_cfg.base_port or 5201 }}
        flow_direction: "{{ traffic_cfg.flow_direction or 'server_to_client' }}"
        parallel_streams: {{ traffic_cfg.parallel_streams or [4] }}
        udp_target_mbps: {{ traffic_cfg.udp_target_mbps or [500] }}
        server_volume_size_gib: {{ volume_cfg.size_gib or 2 }}
{% if volume_cfg.volume_type is defined and volume_cfg.volume_type is not none %}
        server_volume_type: "{{ volume_cfg.volume_type }}"
{% else %}
        server_volume_type: null
{% endif %}
        http_file_count: {{ volume_cfg.file_count or 4 }}
        http_file_size_mib: {{ volume_cfg.file_size_mib or 128 }}
        artifacts_root_dir: "{{ artifacts_cfg.root_dir or 'artifacts' }}"
    runner:
      constant:
        times: 1
        concurrency: 1
        timeout: {{ controller_cfg.command_timeout_seconds or 0 if (controller_cfg.command_timeout_seconds or 0) > 0 else 86400 }}
    sla:
      failure_rate:
        max: 0
